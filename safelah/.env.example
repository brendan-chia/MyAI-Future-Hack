# SafeLah — Environment Variables
# Copy this file to .env and fill in all values

# ── Gemini / Google AI ────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Cloud (for GCS, Speech-to-Text, Vertex AI) ────────────────────────
# Path to your downloaded service account JSON key
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\your-service-account.json

# Google Cloud project ID (the project containing your GCS bucket)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Google Cloud region (used for Speech-to-Text Chirp model)
GOOGLE_CLOUD_REGION=us-central1

# GCS bucket name — must already exist; video analysis uploads go here
# Bucket should have a lifecycle rule to delete objects after 24 hours
GOOGLE_CLOUD_BUCKET=your-gcs-bucket-name

# ── Vertex AI Search ──────────────────────────────────────────────────────────
VERTEX_PROJECT_ID=your-vertex-project-id
VERTEX_ENGINE_ID=your-vertex-engine-id

# ── VirusTotal (optional, for URL scanning) ───────────────────────────────────
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string

# Admin export token (for /api/admin/export and /api/admin/stats)
ADMIN_EXPORT_TOKEN=change-this-to-a-secret-token

# Set to 'true' to skip WhatsApp Web initialisation (e.g. in CI or Cloud Run)
SKIP_WHATSAPP=false
